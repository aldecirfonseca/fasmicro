; URL base do framework (FasMicro)
BASEURL=http://fasmicro/

; Conta para disparo de e-mail
MAIL.HOST=smtp.gmail.com
MAIL.SMTPAuth=true
MAIL.PORT=587
MAIL.SMTPSECURE=tls
MAIL.NOME=seu_nome
MAIL.USER=seu_email@seu_dominio.com
MAIL.SENHA=sua_senha

; Configurações da API REST
; Chave secreta para assinar os tokens JWT (mínimo 32 caracteres, troque antes de ir para produção)
JWT_SECRET=troque_esta_chave_por_uma_string_longa_e_aleatoria
; Expiração do access token em segundos (padrão: 3600 = 1 hora)
JWT_EXPIRE=3600
; Expiração do refresh token em segundos (padrão: 604800 = 7 dias)
JWT_REFRESH_EXPIRE=604800
; Origem permitida nas requisições CORS (* = qualquer origem; em produção, use o domínio real)
API_CORS_ORIGIN=*

; Super usuário
SUPERUSER_EMAIL=seu_email@seudominio.com.br
SUPERUSER_SENHA=sua_senha
SUPERUSER_NOME=seu_nome

; Ambiente da base dados
ENVIRIONMENT=DEVELOPMENT
;ENVIRIONMENT=production

[DEVELOPMENT]
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fasmicro
DB_USER=root
DB_PASSWORD=

[PRODUCTION]
DB_CONNECTION=mysql
DB_HOST=seu_servidor
DB_PORT=3306
DB_DATABASE=sua_base
DB_USER=seu_user
DB_PASSWORD=